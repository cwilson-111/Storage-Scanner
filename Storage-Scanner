        # Collect every file in the scanned tree (iterative; deep-tree safe).
        files = []
        stack = [self.root_node]
        while stack:
            node = stack.pop()
            if node.is_dir:
                stack.extend(node.children)
            else:
                files.append(node)
        files.sort(key=lambda n: n.size, reverse=True)
